{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "lib": ["ESNext"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "rootDir": "src",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "sourceMap": true
    },
    "include": ["./index.ts", "./src/**/*"],
    "exclude": ["node_modules", "dist"]
}